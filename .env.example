# Claude models: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-7
# OpenAI models: gpt-4.1-mini | gpt-4.1 | o3
MODEL=claude-sonnet-4-6

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# AWS (only needed for S3 upload)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=
S3_KEY_PREFIX=runs/
